# Personal submission notes — never publish.
submission.md

# Benchmark sidecars are regenerated on each run; ship the canonical ones
# (mock baselines and committed real-LLM runs) so BENCHMARK_RESULTS.md is
# reproducible from a clean checkout.
src/polyreview/bench/runs/*
!src/polyreview/bench/runs/baseline-mock.json
!src/polyreview/bench/runs/mock.json
!src/polyreview/bench/runs/deepseek-v4-flash.json
!src/polyreview/bench/runs/gpt-5.4-nano.json
